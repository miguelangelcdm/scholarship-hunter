# Gemini API Key (Required for AI Extractor, Scoring, and Essays)
GEMINI_API_KEY="your_google_gemini_api_key"

# Maximum number of search results to fetch from DuckDuckGo per scan (Default: 5)
SEARCH_MAX_RESULTS=5

# Scrapy depth limit (Default: 1. Higher values scrape links inside the target pages)
SCRAPER_DEPTH_LIMIT=1

# Maximum characters to extract from a single webpage (Default: 5000). Helps prevent token burn.
SCRAPER_MAX_TEXT_LENGTH=5000

# Maximum total pages the scraper will crawl in a single execution to prevent runaway loops (Default: 8)
SCRAPER_MAX_PAGES=8
